{
  "schemaVersion": 1,
  "id": "inputbooster",
  "version": "${version}",
  "name": "InputBooster",
  "description": "Ultra-fast input registration with adaptive polling, smarter action draining, and improved debug/profiling utilities for modern Fabric 26.1 clients.",
  "authors": [
    "Ahaduzzaman Khan"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/inputbooster",
    "sources": "https://github.com/ahaduzzamankhan/inputbooster",
    "issues": "https://github.com/ahaduzzamankhan/inputbooster/issues"
  },
  "license": "MIT",
  "icon": "assets/inputbooster/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.inputbooster.InputBoosterMod"
    ]
  },
  "mixins": [
    "inputbooster.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": ">=26.1",
    "java": ">=25"
  },
  "suggests": {
    "modmenu": "*",
    "sodium": "*",
    "iris": "*",
    "lithium": "*",
    "ferritecore": "*"
  },
  "custom": {
    "modmenu": {
      "badges": ["client"]
    }
  }
}
